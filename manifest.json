{
  "manifest_version": 3,
  "name": "AdLoot - Roguelike Ad Extraction",
  "version": "0.1.0",
  "description": "Turn ads into loot vaults. Extract or die trying.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["character.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["character-sprite.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
